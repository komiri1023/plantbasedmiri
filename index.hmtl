<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vegane Ernährungsberatung Zürich & Schweiz | Plantbased Miri</title>
    
    <meta name="description" content="Vegane Ernährungsberatung in Zürich & Schweiz: Nachhaltig abnehmen, Stoffwechsel optimieren & Performance steigern. Wissenschaftlich fundiert.">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .wix-green { background-color: #F1F8F4; }
        .accent-green { background-color: #D1E7DD; }
        .nav-link { font-size: 11px; text-transform: uppercase; letter-spacing: 0.2em; font-weight: 600; }
        .page-section { display: none; }
        .active { display: block; animation: fadeIn 0.5s ease; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body class="bg-white text-gray-900">

    <nav class="fixed w-full z-50 bg-white/90 border-b backdrop-blur-sm">
        <div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
            <a href="#" onclick="showPage('home')">
                <img src="3394_PlantbasedMiri_logo_VC_GR.png" alt="Logo" class="h-8">
            </a>
            <div class="hidden md:flex space-x-8 nav-link">
                <a href="#" onclick="showPage('home')" class="hover:text-green-700">Home</a>
                <a href="#" onclick="showPage('about')" class="hover:text-green-700">Über mich</a>
                <a href="#" onclick="showPage('success')" class="hover:text-green-700">Sikersztorik</a>
                <a href="#" onclick="showPage('contact')" class="hover:text-green-700">Kontakt</a>
            </div>
        </div>
    </nav>

    <div id="home" class="page-section active">
        <section class="pt-32 pb-20 wix-green min-h-screen flex items-center">
            <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
                <div>
                    <h1 class="text-5xl font-bold leading-tight mb-6 text-gray-800">
                        Vegane <br>Ernährungsberatung <br><span class="italic text-green-800 font-light text-4xl">Zürich & Schweiz</span>
                    </h1>
                    <p class="text-lg text-gray-600 mb-10 leading-relaxed">
                        Optimierung deines Energielevels, nachhaltige Gewichtsabnahme und wissenschaftlich fundierte Sporternährung.
                    </p>
                    <button onclick="showPage('contact')" class="bg-gray-900 text-white px-10 py-4 rounded-full font-bold hover:bg-gray-700 transition">Termin buchen</button>
                </div>
                <div>
                    <img src="image_46c5a1.jpg" alt="Mirjana" class="rounded-[40px] shadow-2xl w-full">
                </div>
            </div>
        </section>

        <section class="py-24 bg-white px-6">
            <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-8">
                <div class="p-10 border rounded-[30px] hover:shadow-xl transition">
                    <h3 class="font-bold text-xl mb-2">1:1 Beratung</h3>
                    <p class="text-3xl font-bold mb-6 italic">120 CHF</p>
                    <ul class="text-sm text-gray-500 space-y-2 mb-8">
                        <li>• Erstberatung (60 Min.)</li>
                        <li>• Individuelle Analyse</li>
                    </ul>
                    <button onclick="showPage('contact')" class="w-full py-3 border border-black rounded-full hover:bg-black hover:text-white transition font-bold">Buchen</button>
                </div>
                <div class="p-10 border-2 border-green-200 bg-green-50 rounded-[30px] shadow-lg relative">
                    <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-green-600 text-white px-4 py-1 rounded-full text-[10px] font-bold">EMPFEHLUNG</span>
                    <h3 class="font-bold text-xl mb-2">Erfolgs-Paket</h3>
                    <p class="text-3xl font-bold mb-2 italic">300 CHF</p>
                    <p class="text-green-700 text-xs font-bold mb-6">SPARE 60 CHF!</p>
                    <ul class="text-sm text-gray-600 space-y-2 mb-8">
                        <li>• Erstberatung + 4 Folgetermine</li>
                        <li>• Langfristige Begleitung</li>
                    </ul>
                    <button onclick="showPage('contact')" class="w-full py-3 bg-gray-900 text-white rounded-full font-bold">Jetzt Starten</button>
                </div>
                <div class="p-10 border rounded-[30px] hover:shadow-xl transition">
                    <h3 class="font-bold text-xl mb-2">E-Book</h3>
                    <p class="text-3xl font-bold mb-6 italic">7 CHF</p>
                    <p class="text-sm text-gray-500 mb-8 italic">Diabetes Guide (English)</p>
                    <button class="w-full py-3 bg-gray-200 rounded-full font-bold">Kaufen</button>
                </div>
            </div>
        </section>
    </div>

    <div id="success" class="page-section pt-32 pb-24 accent-green">
        <div class="max-w-6xl mx-auto px-6">
            <h2 class="text-4xl font-bold text-center mb-16 italic">Erfolgsgeschichten</h2>
            <div class="grid md:grid-cols-2 gap-8">
                <div class="bg-white p-8 rounded-[30px] flex items-center gap-6 shadow-sm">
                    <img src="Marianna M.jpg" class="w-24 h-24 rounded-full object-cover">
                    <div>
                        <h4 class="font-bold">Marianna M.</h4>
                        <p class="text-sm italic">"20 kg verloren, Blutdruck stabil!"</p>
                    </div>
                </div>
                <div class="bg-white p-8 rounded-[30px] flex items-center gap-6 shadow-sm">
                    <img src="Andrea U..jpg" class="w-24 h-24 rounded-full object-cover">
                    <div>
                        <h4 class="font-bold">Andrea U.</h4>
                        <p class="text-sm italic">"Typ-1-Diabetes Werte stabiler denn je."</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="about" class="page-section pt-32 pb-24">
        <div class="max-w-4xl mx-auto px-6">
            <h2 class="text-4xl font-bold mb-10 italic">Meine Geschichte</h2>
            <p class="text-lg leading-relaxed text-gray-700 mb-8 italic">
                "Ich bin Mirjana Kovacs... Als selbst Betroffene von Typ-1-Diabetes weiss ich, dass die richtige Ernährung weit mehr ist als nur Essen – sie ist Lebensqualität."
            </p>
            <div class="grid md:grid-cols-2 gap-10 items-center">
                <img src="Screenshot 2026-04-14 101854.jpg" class="rounded-[30px] shadow-lg">
                <div class="bg-gray-50 p-8 rounded-[30px]">
                    <h4 class="font-bold mb-4">Wissenschaftliches Fundament</h4>
                    <p class="text-sm text-gray-600 italic">Zertifizierte Expertin (eCornell University). Über 100 Klienten erfolgreich begleitet.</p>
                </div>
            </div>
        </div>
    </div>

    <div id="contact" class="page-section pt-32 pb-24">
        <div class="max-w-2xl mx-auto px-6 text-center">
            <h2 class="text-3xl font-bold mb-12">Kontakt</h2>
            <form class="text-left space-y-6">
                <div class="grid md:grid-cols-2 gap-6">
                    <input type="text" placeholder="Vorname *" class="w-full border-b border-gray-300 py-3 outline-none focus:border-green-600">
                    <input type="text" placeholder="Nachname *" class="w-full border-b border-gray-300 py-3 outline-none focus:border-green-600">
                </div>
                <input type="email" placeholder="E-Mail *" class="w-full border-b border-gray-300 py-3 outline-none focus:border-green-600">
                <textarea placeholder="Nachricht *" rows="4" class="w-full border-b border-gray-300 py-3 outline-none focus:border-green-600"></textarea>
                <button class="w-full bg-gray-900 text-white py-4 rounded-full font-bold uppercase tracking-widest">Senden</button>
            </form>
        </div>
    </div>

    <footer class="bg-gray-50 py-16 px-6 border-t mt-20">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
            <div>
                <img src="3394_PlantbasedMiri_logo_VC_GR.png" class="h-6 mb-4">
                <p class="text-[10px] text-gray-400 uppercase tracking-widest">Vegane Ernährungsberatung Zürich | Schweiz</p>
            </div>
            <div class="text-xs text-gray-500 font-bold space-x-6">
                <a href="#">Impressum</a>
                <a href="#">Datenschutz</a>
                <span class="text-gray-300 italic">info@plantbasedmiri.com</span>
            </div>
        </div>
    </footer>

    <script>
        function showPage(pageId) {
            document.querySelectorAll('.page-section').forEach(sec => sec.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
            window.scrollTo(0,0);
        }
    </script>
</body>
</html>