            <a href="erfolge.html" class="hover:text-[#8B5E4F] transition-colors">Erfolge</a>
        </div>
        <!-- MÓDOSÍTÁS: Mobilon rejtve (hidden), asztali nézetben látható (md:inline-block) -->
