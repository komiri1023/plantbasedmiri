        .btn-primary {
            background-color: var(--brand-brown);
            color: white;
            padding: 12px 28px;
            border-radius: 50px;
            font-weight: 600;
            display: inline-block;
            transition: 0.3s;
        }

        .content-section {
            background: white;
            border-radius: 40px;
            padding: 3rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        }
    </style>
